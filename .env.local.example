# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: only needed if you later add server-only admin scripts (seeding, etc).
# Never expose this to the browser / never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Instagram feed (Phase 1 uses mock data; flip to "true" once a real token is wired up)
NEXT_PUBLIC_USE_INSTAGRAM_MOCK=true
